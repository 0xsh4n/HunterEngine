# HunterEngine Environment Variables (optional)
# Copy this file to .env and fill in as needed.

# AI testing model (recommended)
ollama pull qwen3:4b
# Local AI (Ollama stays on the host; Docker uses host.docker.internal)
OLLAMA_BASE_URL=http://127.0.0.1:11434
# From inside Docker Compose the default is http://host.docker.internal:11434
# OPENAI_API_KEY=sk-your-key-here

# Proxy configuration
# HTTP_PROXY=socks5://127.0.0.1:9050
# HTTPS_PROXY=socks5://127.0.0.1:9050

# Dashboard
# HUNTERENGINE_DASHBOARD_HOST=127.0.0.1
# HUNTERENGINE_DASHBOARD_PORT=8787

# Note: pip httpx (Python library) is used inside the venv.
# Install ProjectDiscovery httpx separately for live probing:
#   go install -v github.com/projectdiscovery/httpx/cmd/httpx@latest
